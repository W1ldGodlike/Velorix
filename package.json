{
  "name": "fluxalloy",
  "version": "0.1.0",
  "description": "FluxAlloy — desktop app for yt-dlp + ffmpeg workflows, built with Electron, React and TypeScript.",
  "main": "./out/main/index.js",
  "private": true,
  "license": "UNLICENSED",
  "author": "W1ldGodlike",
  "homepage": "https://github.com/W1ldGodlike/FluxAlloy#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/W1ldGodlike/FluxAlloy.git"
  },
  "bugs": {
    "url": "https://github.com/W1ldGodlike/FluxAlloy/issues"
  },
  "keywords": [
    "electron",
    "react",
    "typescript",
    "ffmpeg",
    "ffprobe",
    "yt-dlp",
    "video"
  ],
  "engines": {
    "node": ">=20.19.0"
  },
  "type": "module",
  "scripts": {
    "format": "prettier --write .",
    "lint": "eslint --cache . --max-warnings 0",
    "check": "npm run lint && npm run typecheck && npm run test && npm run check:trusted-hashes && npm run check:rules-explicit && npm run check:field-registries && npm run audit:copy-paste && npm run audit:structural && npm run audit:todo-debt && npm run audit:dead-type-reexports && npm run audit:ipc-architecture && npm run audit:shared-contracts && npm run audit:inventory-sync && npm run check:journal && npm run check:checklist && npm run check:secrets",
    "check:quiet": "node scripts/run-quiet-check.mjs",
    "check:trusted-hashes": "node scripts/validate-trusted-hashes-json.mjs",
    "check:journal": "node scripts/check-journal-numbering.mjs",
    "check:field-registries": "node scripts/check-field-registries.mjs",
    "check:rules-explicit": "node scripts/check-rules-explicit.mjs",
    "check:line-endings": "node scripts/check-line-endings.mjs",
    "check:maint-scripts-layout": "node scripts/check-maint-scripts-layout.mjs",
    "audit:copy-paste": "node scripts/audit-copy-paste-patterns.mjs",
    "audit:inventory": "node scripts/audit-inventory.mjs",
    "audit:structural": "node scripts/audit-structural.mjs",
    "audit:todo-debt": "node scripts/audit-todo-debt.mjs",
    "audit:dead-type-reexports": "node scripts/audit-dead-type-reexports.mjs",
    "audit:ipc-architecture": "node scripts/audit-ipc-architecture.mjs",
    "audit:shared-contracts": "node scripts/audit-shared-contracts.mjs",
    "audit:inventory-sync": "node scripts/audit-inventory-sync.mjs",
    "audit:all": "npm run audit:inventory && npm run audit:inventory-sync && npm run audit:copy-paste && npm run audit:structural && npm run audit:ipc-architecture && npm run audit:shared-contracts",
    "journal:stamp": "node scripts/journal-next-stamp.mjs",
    "journal:consolidate": "node scripts/journal-consolidate.mjs",
    "agent:session": "node scripts/agent-session.mjs",
    "check:checklist": "node scripts/check-checklist-sprint.mjs",
    "check:docs-governance": "node scripts/check-docs-governance.mjs",
    "check:ui-surfaces-guard": "node scripts/check-ui-surfaces-guard.mjs",
    "check:native-main-platform-guard": "node scripts/check-native-main-platform-guard.mjs",
    "check:renderer-state-approach": "node scripts/check-renderer-state-approach.mjs",
    "audit:orphan-scripts": "node scripts/audit-orphan-scripts.mjs",
    "check:locales-json": "node scripts/check-locales-json.mjs",
    "check:locales-ts-overlap": "node scripts/check-locales-ts-overlap.mjs",
    "check:export-preview-hints-locale": "node scripts/check-export-preview-hints-locale.mjs",
    "check:packaged-manual-smoke-parity": "node scripts/check-packaged-manual-smoke-parity.mjs",
    "check:owner-visual-smoke-locale": "node scripts/check-owner-visual-smoke-locale.mjs",
    "check:platform-packaging-scripts": "node scripts/check-platform-packaging-scripts.mjs",
    "check:help-packaged-smoke-docs": "node scripts/check-help-packaged-smoke-docs.mjs",
    "check:help-owner-smoke-docs": "node scripts/check-help-owner-smoke-docs.mjs",
    "check:help-workflow-smoke-crosslinks": "node scripts/check-help-workflow-smoke-crosslinks.mjs",
    "check:help-smoke-guards-package-json": "node scripts/check-help-smoke-guards-package-json.mjs",
    "check:help-terminal-hints-docs": "node scripts/check-help-terminal-hints-docs.mjs",
    "check:packaged-e2e-scenarios-registry": "node scripts/check-packaged-e2e-scenarios-registry.mjs",
    "check:packaged-gui-e2e-playwright-deferred": "node scripts/check-packaged-gui-e2e-playwright-deferred.mjs",
    "check:terminal-summaries-ru": "node scripts/check-terminal-summaries-ru.mjs",
    "check:terminal-data-summaries": "node scripts/check-terminal-data-summaries-quality.mjs",
    "check:terminal-scenario-summaries": "node scripts/check-terminal-scenario-summaries-quality.mjs",
    "check:terminal-contract-hints-shards": "node scripts/check-terminal-contract-hints-shards.mjs",
    "check:terminal-hints-locale": "node scripts/check-terminal-hints-locale.mjs",
    "check:terminal-hints-guards-package-json": "node scripts/check-terminal-hints-guards-package-json.mjs",
    "check:support-bundle-terminal-hints": "node scripts/check-support-bundle-terminal-hints.mjs",
    "locales:terminal-scenario-stream-gloss": "node scripts/apply-terminal-scenario-stream-gloss.mjs",
    "check:ui-copy-quality": "node scripts/check-ui-copy-quality.mjs",
    "theme:tokenize-main-css": "node scripts/theme-tokenize-main-css.mjs",
    "check:secrets": "node scripts/check-no-secrets.mjs",
    "locales:terminal-summaries-ru": "node scripts/apply-terminal-summary-ru.mjs",
    "locales:terminal-flux-pole": "node scripts/inject-flux-summary-pole.mjs",
    "check:release": "npm run check && npm run engines:prepare:win && npm run engines:doctor && npm run build && npm run pack:dir && npm run smoke:packaged-release && npm run audit:moderate",
    "check:release:local": "npm run engines:doctor && npm run build && npm run pack:dir && npm run smoke:packaged-release && npm run audit:moderate",
    "audit:moderate": "npm audit --audit-level=moderate",
    "test": "vitest run --reporter=default",
    "test:coverage": "vitest run --coverage --reporter=default && node scripts/clean-coverage-dir.mjs",
    "test:watch": "vitest",
    "check:tz-artifacts": "node scripts/check-tz-artifacts.mjs",
    "journal:toc": "node scripts/journal-toc.mjs --write",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json --composite false",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json --composite false",
    "typecheck:tests": "tsc --noEmit -p tsconfig.tests.json",
    "typecheck": "npm run typecheck:node && npm run typecheck:web && npm run typecheck:tests",
    "engines:prepare:win": "node scripts/prepare-engines-win.mjs",
    "engines:prepare:win:force": "node scripts/run-prepare-engines-force.mjs",
    "engines:verify-bundled": "node scripts/verify-bundled-engines-hashes.mjs",
    "engines:report-hashes": "node scripts/report-bundled-engines-hashes.mjs",
    "engines:doctor": "npm run engines:verify-bundled && npm run engines:report-hashes && npm run engines:report-hashes -- --versions",
    "predev": "npm run engines:prepare:win",
    "start": "electron-vite preview",
    "dev": "electron-vite dev",
    "agent:once": "npm --prefix scripts/cursor-automation run once --",
    "agent:loop": "npm --prefix scripts/cursor-automation run loop --",
    "agent:loop:cheap": "npm --prefix scripts/cursor-automation run loop:cheap --",
    "agent:typecheck": "npm --prefix scripts/cursor-automation run typecheck",
    "build": "node scripts/write-app-build-info.mjs && npm run typecheck && electron-vite build",
    "postinstall": "electron-builder install-app-deps",
    "build:unpack": "npm run build && electron-builder --dir",
    "pack:dir": "electron-builder --dir",
    "pack:linux:dir": "electron-builder --linux --dir",
    "pack:mac:dir": "electron-builder --mac --dir",
    "verify:win-unpacked": "node scripts/verify-win-unpacked-layout.mjs",
    "verify:linux-unpacked": "node scripts/verify-linux-unpacked-layout.mjs",
    "verify:linux-release": "node scripts/verify-linux-release-artifacts.mjs",
    "verify:mac-unpacked": "node scripts/verify-macos-unpacked-layout.mjs",
    "smoke:packaged-release": "npm run verify:win-unpacked && npm run smoke:packaged-app && npm run smoke:packaged-engines",
    "smoke:packaged-app": "node scripts/smoke-packaged-app.mjs",
    "smoke:packaged-engines": "npm run smoke:packaged-ffprobe && npm run smoke:packaged-ytdlp && npm run smoke:packaged-ffmpeg",
    "smoke:packaged-ffprobe": "node scripts/smoke-packaged-ffprobe.mjs",
    "smoke:packaged-ytdlp": "node scripts/smoke-packaged-ytdlp.mjs",
    "smoke:packaged-ffmpeg": "node scripts/smoke-packaged-ffmpeg.mjs",
    "prebuild:win": "npm run engines:prepare:win",
    "build:win": "npm run build && electron-builder --win",
    "release:win": "npm run engines:prepare:win && npm run engines:doctor && npm run build && electron-builder --win",
    "release:win:force": "npm run engines:prepare:win:force && npm run engines:doctor && npm run build && electron-builder --win",
    "build:mac": "npm run build && electron-builder --mac",
    "build:linux": "npm run build && electron-builder --linux"
  },
  "dependencies": {
    "@electron-toolkit/preload": "^3.0.2",
    "@electron-toolkit/utils": "^4.0.0",
    "extract-zip": "^2.0.1",
    "zustand": "^5.0.5"
  },
  "devDependencies": {
    "@electron-toolkit/eslint-config-prettier": "^3.0.0",
    "@electron-toolkit/eslint-config-ts": "^3.1.0",
    "@electron-toolkit/tsconfig": "^2.0.0",
    "@types/node": "^25.7.0",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "@vitest/coverage-v8": "^4.1.5",
    "electron": "^42.1.0",
    "electron-builder": "^26.0.12",
    "electron-vite": "^5.0.0",
    "eslint": "^9.39.1",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "prettier": "^3.7.4",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "typescript": "^5.9.3",
    "vite": "^7.2.6",
    "vitest": "^4.1.5"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "electron",
      "esbuild"
    ]
  }
}
