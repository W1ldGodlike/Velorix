{
  "name": "fluxalloy",
  "version": "0.1.0",
  "description": "FluxAlloy — desktop app for yt-dlp + ffmpeg workflows, built with Electron, React and TypeScript.",
  "main": "./out/main/index.js",
  "private": true,
  "license": "UNLICENSED",
  "author": "W1ldGodlike",
  "homepage": "https://github.com/W1ldGodlike/FluxAlloy#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/W1ldGodlike/FluxAlloy.git"
  },
  "bugs": {
    "url": "https://github.com/W1ldGodlike/FluxAlloy/issues"
  },
  "keywords": [
    "electron",
    "react",
    "typescript",
    "ffmpeg",
    "ffprobe",
    "yt-dlp",
    "video"
  ],
  "engines": {
    "node": ">=20.19.0"
  },
  "type": "module",
  "scripts": {
    "format": "prettier --write .",
    "lint": "eslint --cache . --max-warnings 0",
    "check": "npm run check:quiet",
    "check:quiet": "node scripts/gate/run-quiet-check.mjs",
    "check:trusted-hashes": "node scripts/gate/validate-trusted-hashes-json.mjs",
    "check:journal": "node scripts/gate/check-journal-numbering.mjs",
    "check:field-registries": "node scripts/gate/check-field-registries.mjs",
    "check:rules-explicit": "node scripts/gate/check-rules-explicit.mjs",
    "check:line-endings": "node scripts/gate/check-line-endings.mjs",
    "check:maint-scripts-layout": "node scripts/gate/check-maint-scripts-layout.mjs",
    "check:scripts-wiring": "node scripts/gate/check-scripts-wiring.mjs",
    "audit:copy-paste": "node scripts/audit/audit-copy-paste-patterns.mjs",
    "audit:inventory": "node scripts/audit/audit-inventory.mjs",
    "audit:structural": "node scripts/audit/audit-structural.mjs",
    "audit:todo-debt": "node scripts/audit/audit-todo-debt.mjs",
    "audit:dead-type-reexports": "node scripts/audit/audit-dead-type-reexports.mjs",
    "audit:ipc-architecture": "node scripts/audit/audit-ipc-architecture.mjs",
    "audit:shared-contracts": "node scripts/audit/audit-shared-contracts.mjs",
    "audit:inventory-sync": "node scripts/audit/audit-inventory-sync.mjs",
    "audit:all": "npm run audit:inventory && npm run audit:inventory-sync && npm run audit:copy-paste && npm run audit:structural && npm run audit:ipc-architecture && npm run audit:shared-contracts",
    "journal:stamp": "node scripts/maint/journal-next-stamp.mjs",
    "journal:consolidate": "node scripts/maint/journal-consolidate.mjs",
    "agent:session": "node scripts/maint/agent-session.mjs",
    "check:checklist": "node scripts/gate/check-checklist-sprint.mjs",
    "checklist:number": "node scripts/maint/number-implementation-checklist.mjs",
    "check:docs-governance": "node scripts/gate/check-docs-governance.mjs",
    "check:ui-surfaces-guard": "node scripts/gate/check-ui-surfaces-guard.mjs",
    "check:native-main-platform-guard": "node scripts/gate/check-native-main-platform-guard.mjs",
    "check:renderer-state-approach": "node scripts/gate/check-renderer-state-approach.mjs",
    "audit:orphan-scripts": "node scripts/audit/audit-orphan-scripts.mjs",
    "audit:terminal-hints-prune": "node scripts/audit/audit-terminal-hints-prune.mjs",
    "check:locales-json": "node scripts/gate/check-locales-json.mjs",
    "check:locales-ts-overlap": "node scripts/gate/check-locales-ts-overlap.mjs",
    "check:export-preview-hints-locale": "node scripts/gate/check-export-preview-hints-locale.mjs",
    "check:packaged-manual-smoke-parity": "node scripts/gate/check-packaged-manual-smoke-parity.mjs",
    "check:owner-visual-smoke-locale": "node scripts/gate/check-owner-visual-smoke-locale.mjs",
    "check:platform-packaging-scripts": "node scripts/gate/check-platform-packaging-scripts.mjs",
    "check:help-packaged-smoke-docs": "node scripts/gate/check-help-packaged-smoke-docs.mjs",
    "check:help-owner-smoke-docs": "node scripts/gate/check-help-owner-smoke-docs.mjs",
    "check:help-workflow-smoke-crosslinks": "node scripts/gate/check-help-workflow-smoke-crosslinks.mjs",
    "check:help-smoke-guards-package-json": "node scripts/gate/check-help-smoke-guards-package-json.mjs",
    "check:help-terminal-hints-docs": "node scripts/gate/check-help-terminal-hints-docs.mjs",
    "check:packaged-e2e-scenarios-registry": "node scripts/gate/check-packaged-e2e-scenarios-registry.mjs",
    "check:packaged-gui-e2e-playwright-deferred": "node scripts/gate/check-packaged-gui-e2e-playwright-deferred.mjs",
    "check:terminal-summaries-ru": "node scripts/gate/check-terminal-summaries-ru.mjs",
    "check:terminal-data-summaries": "node scripts/gate/check-terminal-data-summaries-quality.mjs",
    "check:terminal-scenario-summaries": "node scripts/gate/check-terminal-scenario-summaries-quality.mjs",
    "check:terminal-contract-hints-shards": "node scripts/gate/check-terminal-contract-hints-shards.mjs",
    "check:terminal-hints-locale": "node scripts/gate/check-terminal-hints-locale.mjs",
    "check:terminal-hints-guards-package-json": "node scripts/gate/check-terminal-hints-guards-package-json.mjs",
    "check:support-bundle-terminal-hints": "node scripts/gate/check-support-bundle-terminal-hints.mjs",
    "locales:terminal-scenario-stream-gloss": "node scripts/maint/apply-terminal-scenario-stream-gloss.mjs",
    "check:ui-copy-quality": "node scripts/gate/check-ui-copy-quality.mjs",
    "theme:tokenize-main-css": "node scripts/maint/theme-tokenize-main-css.mjs",
    "sync:help-playwright-paragraphs": "node scripts/maint/sync-help-playwright-paragraphs.mjs",
    "check:secrets": "node scripts/gate/check-no-secrets.mjs",
    "locales:terminal-summaries-ru": "node scripts/maint/apply-terminal-summary-ru.mjs",
    "locales:terminal-flux-pole": "node scripts/maint/inject-flux-summary-pole.mjs",
    "check:release": "npm run check && npm run engines:prepare:win && npm run engines:doctor && npm run build && npm run pack:dir && npm run smoke:packaged-release && npm run audit:moderate",
    "check:release:local": "npm run engines:doctor && npm run build && npm run pack:dir && npm run smoke:packaged-release && npm run audit:moderate",
    "audit:moderate": "npm audit --audit-level=moderate",
    "test": "vitest run --reporter=default",
    "test:coverage": "vitest run --coverage --reporter=default && node scripts/maint/clean-coverage-dir.mjs",
    "test:watch": "vitest",
    "test:e2e:gui": "node scripts/e2e/run-planned-gui-e2e-playwright.mjs",
    "check:tz-artifacts": "node scripts/gate/check-tz-artifacts.mjs",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json --composite false",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json --composite false",
    "typecheck:tests": "tsc --noEmit -p tsconfig.tests.json",
    "typecheck": "npm run typecheck:node && npm run typecheck:web && npm run typecheck:tests",
    "engines:prepare:win": "node scripts/release/prepare-engines-win.mjs",
    "engines:prepare:win:force": "node scripts/release/run-prepare-engines-force.mjs",
    "engines:prepare:mac": "node scripts/release/prepare-engines-bundled-first.mjs mac",
    "engines:prepare:linux": "node scripts/release/prepare-engines-bundled-first.mjs linux",
    "engines:verify-bundled": "node scripts/release/verify-bundled-engines-hashes.mjs",
    "engines:report-hashes": "node scripts/release/report-bundled-engines-hashes.mjs",
    "engines:doctor": "npm run engines:verify-bundled && npm run engines:report-hashes && npm run engines:report-hashes -- --versions",
    "predev": "node scripts/release/predev-engines.mjs",
    "start": "electron-vite preview",
    "dev": "electron-vite dev",
    "agent:once": "npm --prefix scripts/cursor-automation run once --",
    "agent:loop": "npm --prefix scripts/cursor-automation run loop --",
    "agent:loop:cheap": "npm --prefix scripts/cursor-automation run loop:cheap --",
    "agent:typecheck": "npm --prefix scripts/cursor-automation run typecheck",
    "build": "node scripts/release/write-app-build-info.mjs && npm run typecheck && electron-vite build",
    "postinstall": "electron-builder install-app-deps",
    "build:unpack": "npm run build && electron-builder --dir",
    "pack:dir": "electron-builder --dir",
    "pack:linux:dir": "electron-builder --linux --dir",
    "pack:mac:dir": "electron-builder --mac --dir",
    "verify:win-unpacked": "node scripts/release/verify-win-unpacked-layout.mjs",
    "verify:linux-unpacked": "node scripts/release/verify-linux-unpacked-layout.mjs",
    "verify:linux-release": "node scripts/release/verify-linux-release-artifacts.mjs",
    "verify:mac-unpacked": "node scripts/release/verify-macos-unpacked-layout.mjs",
    "smoke:packaged-release": "npm run verify:win-unpacked && npm run smoke:packaged-app && npm run smoke:packaged-engines",
    "smoke:packaged-app": "node scripts/release/smoke-packaged-app.mjs",
    "smoke:packaged-engines": "npm run smoke:packaged-ffprobe && npm run smoke:packaged-ytdlp && npm run smoke:packaged-ffmpeg",
    "smoke:packaged-ffprobe": "node scripts/release/smoke-packaged-ffprobe.mjs",
    "smoke:packaged-ytdlp": "node scripts/release/smoke-packaged-ytdlp.mjs",
    "smoke:packaged-ffmpeg": "node scripts/release/smoke-packaged-ffmpeg.mjs",
    "prebuild:win": "npm run engines:prepare:win",
    "build:win": "npm run build && electron-builder --win",
    "release:win": "npm run engines:prepare:win && npm run engines:doctor && npm run build && electron-builder --win",
    "release:win:force": "npm run engines:prepare:win:force && npm run engines:doctor && npm run build && electron-builder --win",
    "build:mac": "npm run build && electron-builder --mac",
    "build:linux": "npm run build && electron-builder --linux"
  },
  "dependencies": {
    "@electron-toolkit/preload": "^3.0.2",
    "@electron-toolkit/utils": "^4.0.0",
    "extract-zip": "^2.0.1",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@electron-toolkit/eslint-config-prettier": "^3.0.0",
    "@electron-toolkit/eslint-config-ts": "^3.1.0",
    "@electron-toolkit/tsconfig": "^2.0.0",
    "@playwright/test": "^1.52.0",
    "@types/node": "^25.9.1",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "@vitest/coverage-v8": "^4.1.6",
    "electron": "^42.2.0",
    "electron-builder": "^26.0.12",
    "electron-vite": "^5.0.0",
    "eslint": "^9.39.4",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "prettier": "^3.7.4",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "typescript": "^6.0.3",
    "vite": "^8.0.13",
    "vitest": "^4.1.6"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "electron",
      "esbuild"
    ]
  }
}
