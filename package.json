{
  "name": "fluxalloy",
  "version": "0.1.0",
  "description": "FluxAlloy — desktop app for yt-dlp + ffmpeg workflows, built with Electron, React and TypeScript.",
  "main": "./out/main/index.js",
  "private": true,
  "license": "UNLICENSED",
  "author": "W1ldGodlike",
  "homepage": "https://github.com/W1ldGodlike/FluxAlloy#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/W1ldGodlike/FluxAlloy.git"
  },
  "bugs": {
    "url": "https://github.com/W1ldGodlike/FluxAlloy/issues"
  },
  "keywords": [
    "electron",
    "react",
    "typescript",
    "ffmpeg",
    "ffprobe",
    "yt-dlp",
    "video"
  ],
  "engines": {
    "node": ">=20.19.0"
  },
  "type": "module",
  "scripts": {
    "format": "prettier --write .",
    "lint": "eslint --cache .",
    "check": "npm run lint && npm run typecheck && npm run test && npm run check:trusted-hashes && npm run check:journal && npm run check:secrets",
    "check:quiet": "node scripts/run-quiet-check.mjs",
    "check:trusted-hashes": "node scripts/validate-trusted-hashes-json.mjs",
    "check:journal": "node scripts/check-journal-numbering.mjs",
    "check:secrets": "node scripts/check-no-secrets.mjs",
    "check:release": "npm run check && npm run engines:prepare:win && npm run engines:doctor && npm run build && npm run pack:dir && npm run audit:moderate",
    "audit:moderate": "npm audit --audit-level=moderate",
    "test": "vitest run --reporter=default",
    "test:watch": "vitest",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json --composite false",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json --composite false",
    "typecheck:tests": "tsc --noEmit -p tsconfig.tests.json",
    "typecheck": "npm run typecheck:node && npm run typecheck:web && npm run typecheck:tests",
    "engines:prepare:win": "node scripts/prepare-engines-win.mjs",
    "engines:prepare:win:force": "node scripts/run-prepare-engines-force.mjs",
    "engines:verify-bundled": "node scripts/verify-bundled-engines-hashes.mjs",
    "engines:report-hashes": "node scripts/report-bundled-engines-hashes.mjs",
    "engines:doctor": "npm run engines:verify-bundled && npm run engines:report-hashes && npm run engines:report-hashes -- --versions",
    "predev": "npm run engines:prepare:win",
    "start": "electron-vite preview",
    "dev": "electron-vite dev",
    "agent:once": "npm --prefix scripts/cursor-automation run once --",
    "agent:loop": "npm --prefix scripts/cursor-automation run loop --",
    "agent:loop:cheap": "npm --prefix scripts/cursor-automation run loop:cheap --",
    "agent:typecheck": "npm --prefix scripts/cursor-automation run typecheck",
    "build": "npm run typecheck && electron-vite build",
    "postinstall": "electron-builder install-app-deps",
    "build:unpack": "npm run build && electron-builder --dir",
    "pack:dir": "electron-builder --dir",
    "prebuild:win": "npm run engines:prepare:win",
    "build:win": "npm run build && electron-builder --win",
    "release:win": "npm run engines:prepare:win && npm run engines:doctor && npm run build && electron-builder --win",
    "release:win:force": "npm run engines:prepare:win:force && npm run engines:doctor && npm run build && electron-builder --win",
    "build:mac": "npm run build && electron-builder --mac",
    "build:linux": "npm run build && electron-builder --linux"
  },
  "dependencies": {
    "@electron-toolkit/preload": "^3.0.2",
    "@electron-toolkit/utils": "^4.0.0",
    "extract-zip": "^2.0.1"
  },
  "devDependencies": {
    "@electron-toolkit/eslint-config-prettier": "^3.0.0",
    "@electron-toolkit/eslint-config-ts": "^3.1.0",
    "@electron-toolkit/tsconfig": "^2.0.0",
    "@types/node": "^22.19.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "electron": "^39.2.6",
    "electron-builder": "^26.0.12",
    "electron-vite": "^5.0.0",
    "eslint": "^9.39.1",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "prettier": "^3.7.4",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "typescript": "^5.9.3",
    "vite": "^7.2.6",
    "vitest": "^4.1.5"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "electron",
      "esbuild"
    ]
  }
}
