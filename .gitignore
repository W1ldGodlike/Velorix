# Тяжёлые зависимости восстанавливаются через npm install и фиксируются package-lock.json.
node_modules

# Результаты сборки electron-vite/electron-builder; их можно пересоздать командами npm run build*.
dist
out
.DS_Store

# Runtime-движки кладём в bin/ перед релизной сборкой, но сами бинарники в Git не храним.
bin/*
!bin/.gitkeep
!bin/README.md

# Кэш инкрементальной компиляции TypeScript (локально).
*.tsbuildinfo

# Локальный кэш линтера и любые временные логи не должны попадать в историю.
.eslintcache
*.log*

# Мусор IDE/ОС (не коммитить случайно при снятии ограничений .gitignore).
Thumbs.db
Desktop.ini
.idea
*.swp

# Альтернативные lockfile не используем, пока проект стандартизован на npm.
pnpm-lock.yaml
yarn.lock

# Временные файлы сообщений коммитов (PowerShell не поддерживает heredoc, ред-сценарий через --file).
.git-commit-msg.tmp

# Runtime-данные (настройки, логи, загрузки) — `<installRoot>/app-data/`, не в Git.
/app-data/

# Счётчик marathon-итераций агента (локально).
docs/.agent-session.json

# Локальные секреты (Cursor SDK automation и прочее).
.env
**/.env
**/.env.*
!.env.example
!**/.env.example
