# Обязательный секрет Cursor SDK. Реальный ключ храните только в локальном .env.
CURSOR_API_KEY=crsr_replace_me

# Модель SDK. `auto` здесь не используем; дефолт и комментарии см. в src/sdk-settings.ts.
# CURSOR_MODEL=default

# Число итераций loop, если не передан CLI-флаг --max-steps.
# MAX_STEPS=5

# Сколько итераций держать в одном Agent.create перед dispose/recreate.
# Для 200/300 шагов держите 1, чтобы минимизировать Cache Read.
# SDK_SESSION_STEPS=1

# Печатать assistant/thinking stream в консоль: 1/true/yes/on включает.
# На long-loop >20 шагов автоматически выключается, если не задан SDK_ALLOW_VERBOSE_LONG_LOOP=1.
# VERBOSE=0

# Диагностический override: разрешить VERBOSE на длинных 200/300-step циклах.
# SDK_ALLOW_VERBOSE_LONG_LOOP=0

# Лимит stream-лога при VERBOSE=1, чтобы диагностика не превращалась в простыню.
# VERBOSE_MAX_CHARS=8000

# Пауза между итерациями loop в миллисекундах.
# STEP_DELAY_MS=400

# Альтернативная папка с initial.txt и continue.txt.
# PROMPTS_DIR=

# Число повторов при retryable CursorAgentError/сетевых/transport-сбоях.
# LOOP_STEP_RETRY_MAX=10

# Базовая пауза transport retry в миллисекундах; дальше растёт экспоненциально.
# LOOP_STEP_RETRY_BASE_MS=2000

# Повторять любой result.status=error той же итерацией. По умолчанию выключено:
# без этого повторяются только быстрые error-run, похожие на transient SDK/runtime-сбой.
# LOOP_RETRY_RUN_ERROR=0

# Число повторов для status=error; по умолчанию наследует LOOP_STEP_RETRY_MAX.
# LOOP_RUN_ERROR_RETRY_MAX=

# Базовая пауза для повторов status=error; по умолчанию наследует LOOP_STEP_RETRY_BASE_MS.
# LOOP_RUN_ERROR_RETRY_BASE_MS=

# Прокинуть local.settingSources: ['all'] в SDK. Обычно не нужно.
# SETTING_SOURCES_ALL=0
